      "settings": {
        "foreground": "#A8A090"
      }
    },
    {
      "name": "Assignment",
      "scope": "keyword.operator.assignment",
      "settings": {
        "foreground": "#A8A090"
      }
    },
    {
      "name": "Arithmetic/Comparison",
      "scope": [
